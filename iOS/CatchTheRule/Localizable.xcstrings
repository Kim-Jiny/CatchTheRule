    "unlock_msg": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You cleared 5 chapters! Two new modes are open — find the rules hidden in shapes, and crack logic puzzles."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "5챕터를 클리어했어요! 새로운 모드 두 개가 열렸어요 — 도형 속 규칙 찾기와 논리 퍼즐에 도전해 보세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "5チャプタークリア！新しいモードが2つ解放 — 図形のルール探しとロジックパズルに挑戦しよう。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通关5个章节！开启两种新模式 — 图形找规律和逻辑谜题。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Superaste 5 capítulos! Se abrieron dos modos nuevos: encuentra las reglas en las figuras y resuelve acertijos de lógica."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu as terminé 5 chapitres ! Deux nouveaux modes s'ouvrent — trouve les règles des formes et résous des énigmes de logique."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast 5 Kapitel geschafft! Zwei neue Modi sind offen — finde die Regeln in den Formen und löse Logikrätsel."
          }
        }
      }
    },
