    "reset_confirm_msg": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All stage progress, stars, and records will be deleted. This cannot be undone."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 단계 진행과 별, 기록이 삭제됩니다. 되돌릴 수 없어요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての進行・スター・記録が削除されます。元に戻せません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有进度、星星和记录都会被删除，无法恢复。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se borrarán todo el progreso, las estrellas y los registros. No se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toute la progression, les étoiles et les records seront supprimés. Irréversible."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aller Fortschritt, Sterne und Einträge werden gelöscht. Nicht umkehrbar."
